{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "lmstudio-community/Qwen3.5-9B-GGUF": {
          "name": "Qwen3.5-9B-GGUF (local)"
        }
      }
    }
  },
  "model": "lmstudio/lmstudio-community/Qwen3.5-9B-GGUF",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "C:\\CODE\\sosoeat"],
      "enabled": true,
      "timeout": 10000
    }
  },
  "permission": {
    "external_directory": {
      "C:\\CODE\\sosoeat\\**": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "C:\\CODE\\sosoeat\\**": "allow"
    }
  }
}
